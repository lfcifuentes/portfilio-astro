---
import { Icon } from "astro-icon/components";

interface Props {
  content?: {
    sectionTag: string;
    titlePrefix: string;
    titleAccent: string;
    subtitle: string;
    linkedInLabel: string;
    githubLabel: string;
  };
}

const {
  content = {
    sectionTag: 'Contact',
    titlePrefix: "Let's",
    titleAccent: 'talk.',
    subtitle:
      'Open to Senior Backend Engineer and Tech Lead roles — remote or Colombia. Especially interested in high-scale, distributed systems challenges.',
    linkedInLabel: 'LinkedIn',
    githubLabel: 'GitHub',
  },
} = Astro.props as Props;
---

<style>
  #contact {
    padding: 100px 0;
  }

  .contact-inner {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .contact-inner .section-tag {
    justify-content: center;
  }

  .contact-inner .section-tag::before {
    display: none;
  }

  .contact-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 48px;
    font-weight: 900;
    letter-spacing: -2px;
    line-height: 1;
    margin-bottom: 16px;
  }

  .contact-sub {
    font-size: 15px;
    color: var(--muted);
    margin-bottom: 36px;
    line-height: 1.7;
  }

  .contact-links {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .contact-link {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    padding: 12px 24px;
    border-radius: 6px;
    text-decoration: none;
    letter-spacing: 1px;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .contact-link.primary {
    background: var(--blue);
    color: #fff;
    border: 1px solid var(--blue);
  }

  .contact-link.primary:hover {
    background: #2570e0;
  }

  .contact-link.secondary {
    border: 1px solid var(--border2);
    color: var(--muted);
  }

  .contact-link.secondary:hover {
    border-color: var(--blue);
    color: var(--text);
  }

  .svg-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    stroke: currentColor;
  }

  .contact-link .svg-icon {
    margin-right: 2px;
  }

  .contact-link.primary .svg-icon {
    color: #fff;
  }

  .contact-link.secondary .svg-icon {
    color: var(--muted);
  }

  .contact-link.secondary:hover .svg-icon {
    color: var(--blue);
  }

  .section-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--green);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .section-tag::before {
    content: '';
    width: 20px;
    height: 1px;
    background: var(--green);
  }

  @media (max-width: 700px) {
    #contact {
      padding: 72px 0;
    }

    .contact-title {
      font-size: 34px;
    }
  }

  @media (max-width: 520px) {
    .contact-link {
      width: 100%;
      justify-content: center;
      padding: 12px 16px;
    }
  }
</style>

<section id="contact">
  <div class="container">
    <div class="contact-inner">
      <div class="section-tag">{content.sectionTag}</div>
      <div class="contact-title">{content.titlePrefix} <span style="color:var(--blue)">{content.titleAccent}</span></div>
      <p class="contact-sub">
        {content.subtitle}
      </p>
      <div class="contact-links">
        <a href="mailto:luis@lcifuentes.dev" class="contact-link primary">
          <Icon name="tabler:mail" size={20} />
          luis@lcifuentes.dev
        </a>
        <a href="https://www.linkedin.com/in/luis-fernando-cifuentes-3a6a90119/" target="_blank" class="contact-link secondary">
          <Icon name="simple-icons:linkedin" size={20} />
          {content.linkedInLabel}
        </a>
        <a href="https://github.com/lfcifuentes" target="_blank" class="contact-link secondary">
          <Icon name="simple-icons:github" size={20} />
          {content.githubLabel}
        </a>
      </div>
    </div>
  </div>
</section>
