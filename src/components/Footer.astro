---
interface Props {
  content?: {
    copyright: string;
    builtWithPrefix: string;
    highlightedWord: string;
    builtWithSuffix: string;
  };
}

const {
  content = {
    copyright: '© 2026 Luis Fernando Cifuentes',
    builtWithPrefix: 'Built with',
    highlightedWord: 'Go',
    builtWithSuffix: 'mindset · Deployed with Astro',
  },
} = Astro.props as Props;
---

<style>
  footer {
    border-top: 1px solid var(--border2);
    padding: 28px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .footer-left {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: #445b7a; /* #2a3a50 */
  }

  .footer-right {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: #445b7a; /* #2a3a50 */
  }

  .footer-right span {
    color: var(--blue);
  }

  @media (max-width: 900px) {
    footer {
      padding: 24px;
      flex-direction: column;
      gap: 8px;
      text-align: center;
    }
  }
</style>

<footer>
  <div class="footer-left">{content.copyright}</div>
  <div class="footer-right">{content.builtWithPrefix} <span>{content.highlightedWord}</span> {content.builtWithSuffix}</div>
</footer>
