---
interface Props {
  content?: {
    eyebrow: string;
    role: string;
    description: string;
    viewProjects: string;
    linkedIn: string;
    pythonCvCta: string;
    goCvCta: string;
    termFile: string;
    termLoading: string;
    termStack: string;
    termStatus: string;
    termExp: string;
    termLang: string;
    termArch: string;
    statYearsValue: string;
    statYearsLabel: string;
    statUsersValue: string;
    statUsersLabel: string;
    statSystemsValue: string;
    statSystemsLabel: string;
    statTechnologiesValue: string;
    statTechnologiesLabel: string;
  };
}

const {
  content = {
    eyebrow: 'Available for Senior / Lead roles',
    role: 'Senior Backend Engineer · Go · Distributed Systems',
    description:
      'Building high-performance distributed systems with +8 years of experience. Full ownership from architecture to production, including rebuilding critical systems from scratch while working directly with clients.',
    viewProjects: 'View projects',
    linkedIn: 'LinkedIn →',
    pythonCvCta: 'Download Python CV',
    goCvCta: 'Download Go CV',
    termFile: '~ engineer.go',
    termLoading: 'distributed systems',
    termStack: 'Go · K8s · Redis · AWS',
    termStatus: '● production ready',
    termExp: '+8 years',
    termLang: 'Go (primary)',
    termArch: 'event-driven · microservices',
    statYearsValue: '8+',
    statYearsLabel: 'years building backend',
    statUsersValue: '70K+',
    statUsersLabel: 'users served in production',
    statSystemsValue: '10+',
    statSystemsLabel: 'systems and APIs delivered',
    statTechnologiesValue: '8+',
    statTechnologiesLabel: 'technologies used in production',
  },
} = Astro.props as Props;

const pythonCvUrl = '/pdf/CV_Luis_Cifuentes_Python.pdf';
const goCvUrl = '/pdf/CV_Luis_Cifuentes.pdf';
---

<style>
  #hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 80px;
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 60px;
    align-items: center;
    width: 100%;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    padding: 6px 14px;
    border: 1px solid rgba(34, 197, 94, 0.35);
    border-radius: 999px;
    background: rgba(34, 197, 94, 0.07);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: #4ade80;
    letter-spacing: 2px;
    text-transform: uppercase;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 0.1s;
  }

  .availability-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    flex-shrink: 0;
    box-shadow: 0 0 6px rgba(34, 197, 94, 0.6);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 6px rgba(34, 197, 94, 0.6); }
    50% { opacity: 0.6; box-shadow: 0 0 12px rgba(34, 197, 94, 0.9); }
  }

  .hero-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(52px, 6vw, 80px);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -3px;
    margin-bottom: 12px;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 0.2s;
  }

  .hero-name .accent {
    color: var(--blue);
  }

  .hero-role {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 14px;
    color: var(--muted);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 0.3s;
  }

  .hero-desc {
    font-size: 16px;
    color: #9aa8bc;
    line-height: 1.75;
    max-width: 520px;
    margin-bottom: 36px;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 0.4s;
  }

  .hero-desc strong {
    color: var(--text);
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 0.5s;
  }

  .btn-primary {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    padding: 12px 28px;
    background: var(--blue);
    color: #fff;
    border: none;
    border-radius: 6px;
    text-decoration: none;
    letter-spacing: 1px;
    transition: all 0.2s;
    cursor: pointer;
  }

  .btn-primary:hover {
    background: #2570e0;
    transform: translateY(-1px);
  }

  .btn-outline {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    padding: 12px 28px;
    border: 1px solid var(--border2);
    color: var(--muted);
    border-radius: 6px;
    text-decoration: none;
    letter-spacing: 1px;
    transition: all 0.2s;
  }

  .btn-outline:hover {
    border-color: var(--blue);
    color: var(--text);
  }

  .terminal-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    opacity: 0;
    animation: fadeLeft 0.7s ease forwards 0.3s;
  }

  .term-bar {
    background: var(--bg3);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid var(--border);
  }

  .terminal-dots {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.85;
    transition: opacity 0.2s, box-shadow 0.2s;
    box-shadow: 0 0 6px rgba(52, 131, 250, 0.1);
  }

  .dot:hover {
    opacity: 1;
    box-shadow: 0 0 12px rgba(52, 131, 250, 0.3);
  }

  .dot-r {
    background: #ef4444;
    box-shadow: 0 0 6px rgba(239, 68, 68, 0.2);
  }

  .dot-y {
    background: #f59e0b;
    box-shadow: 0 0 6px rgba(245, 158, 11, 0.2);
  }

  .dot-g {
    background: #22c55e;
    box-shadow: 0 0 6px rgba(34, 197, 94, 0.2);
  }

  .term-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: #3a4a60;
    margin-left: 8px;
    letter-spacing: 1px;
  }

  .term-body {
    padding: 24px;
  }

  .t-line {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    margin-bottom: 8px;
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .t-p {
    color: var(--blue);
    flex-shrink: 0;
  }

  .t-c {
    color: var(--green);
  }

  .t-o {
    color: var(--muted);
    padding-left: 14px;
    flex: 1;
  }

  .t-v {
    color: #c8d0e0;
  }

  .t-ok {
    color: var(--green);
  }

  .t-num {
    color: #f59e0b;
  }

  .cursor {
    display: inline-block;
    width: 8px;
    height: 16px;
    background: var(--green);
    vertical-align: middle;
    margin-left: 3px;
    animation: blink 1s infinite;
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .hero-name {
      line-height: 1;
      letter-spacing: -2px;
    }

    .hero-desc {
      max-width: 100%;
    }

    .terminal-card {
      max-width: 100%;
    }

  }

  @media (max-width: 700px) {
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-actions a {
      text-align: center;
    }

  }

  @media (max-width: 520px) {
    #hero {
      padding-top: 110px;
    }

    .hero-eyebrow {
      letter-spacing: 2.5px;
    }

    .hero-role {
      font-size: 12px;
      letter-spacing: 2px;
    }

    .hero-desc {
      font-size: 15px;
      line-height: 1.7;
    }

    .term-body {
      padding: 16px;
    }

    .t-line {
      font-size: 12px;
      gap: 7px;
    }
  }

  @media (max-width: 375px) {
    #hero {
      padding-top: 70px;
    }

    .hero-name {
      font-size: clamp(40px, 5vw, 52px);
      letter-spacing: -1px;
    }

    .hero-eyebrow {
      font-size: 10px;
      letter-spacing: 2px;
    }

    .hero-role {
      font-size: 11px;
      letter-spacing: 1.5px;
    }

    .hero-desc {
      font-size: 13px;
      line-height: 1.6;
    }

    .terminal-card {
      border-radius: 8px;
    }

    .term-bar {
      padding: 10px 12px;
    }

    .term-body {
      padding: 14px;
    }

    .t-line {
      font-size: 11px;
      gap: 6px;
    }

    .btn-primary,
    .btn-outline {
      font-size: 12px;
      padding: 10px 20px;
    }
  }
</style>

<section id="hero">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="container">
    <div class="hero-inner">
      <div class="hero-left">
        <div class="hero-eyebrow">
          <span class="availability-dot"></span>
          {content.eyebrow}
        </div>
        <h1 class="hero-name">
          Luis<br />
          Fernando<br />
          <span class="accent">Cifuentes.</span>
        </h1>
        <div class="hero-role">{content.role}</div>
        <p class="hero-desc">
          {content.description}
        </p>
        <div class="hero-actions">
          <a href="#projects" class="btn-primary">{content.viewProjects}</a>
          <a href="https://www.linkedin.com/in/luis-fernando-cifuentes-3a6a90119/" target="_blank" class="btn-outline">{content.linkedIn}</a>
          <a href={pythonCvUrl} class="btn-outline" download="CV_Luis_Cifuentes_Python.pdf">{content.pythonCvCta}</a>
          <a href={goCvUrl} class="btn-outline" download="CV_Luis_Cifuentes.pdf">{content.goCvCta}</a>
        </div>
      </div>

      <div class="terminal-card">
        <div class="term-bar">
          <div class="terminal-dots">
            <div class="dot dot-r"></div>
            <div class="dot dot-y"></div>
            <div class="dot dot-g"></div>
          </div>
          <span class="term-title">{content.termFile}</span>
        </div>
        <div class="term-body">
          <div class="t-line">
            <span class="t-p">$</span><span class="t-c">go run engineer.go</span><span class="cursor"></span>
          </div>
          <div class="t-line">
            <span class="t-o">&gt; loading: <span class="t-v">{content.termLoading}</span></span>
          </div>
          <div class="t-line">
            <span class="t-o">&gt; stack:   <span class="t-v">{content.termStack}</span></span>
          </div>
          <div class="t-line">
            <span class="t-o">&gt; status:  <span class="t-ok">{content.termStatus}</span></span>
          </div>
          <div class="t-line">
            <span class="t-o">&gt; exp:     <span class="t-num">{content.termExp}</span></span>
          </div>
          <div class="t-line">
            <span class="t-o">&gt; lang:    <span class="t-v">{content.termLang}</span></span>
          </div>
          <div class="t-line">
            <span class="t-o">&gt; arch:    <span class="t-v">{content.termArch}</span></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
