<style>
  #hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 80px;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 60px;
    align-items: center;
    width: 100%;
  }

  .hero-eyebrow {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: var(--green);
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 0.1s;
  }

  .hero-eyebrow::before {
    content: '';
    width: 30px;
    height: 1px;
    background: var(--green);
  }

  .hero-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(52px, 6vw, 80px);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -3px;
    margin-bottom: 12px;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 0.2s;
  }

  .hero-name .accent {
    color: var(--blue);
  }

  .hero-role {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 14px;
    color: var(--muted);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 0.3s;
  }

  .hero-desc {
    font-size: 16px;
    color: #9aa8bc;
    line-height: 1.75;
    max-width: 520px;
    margin-bottom: 36px;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 0.4s;
  }

  .hero-desc strong {
    color: var(--text);
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 0.5s;
  }

  .btn-primary {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    padding: 12px 28px;
    background: var(--blue);
    color: #fff;
    border: none;
    border-radius: 6px;
    text-decoration: none;
    letter-spacing: 1px;
    transition: all 0.2s;
    cursor: pointer;
  }

  .btn-primary:hover {
    background: #2570e0;
    transform: translateY(-1px);
  }

  .btn-outline {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    padding: 12px 28px;
    border: 1px solid var(--border2);
    color: var(--muted);
    border-radius: 6px;
    text-decoration: none;
    letter-spacing: 1px;
    transition: all 0.2s;
  }

  .btn-outline:hover {
    border-color: var(--blue);
    color: var(--text);
  }

  .terminal-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    opacity: 0;
    animation: fadeLeft 0.7s ease forwards 0.3s;
  }

  .term-bar {
    background: var(--bg3);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid var(--border);
  }

  .terminal-dots {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    opacity: 0.85;
    transition: opacity 0.2s, box-shadow 0.2s;
    box-shadow: 0 0 6px rgba(52, 131, 250, 0.1);
  }

  .dot:hover {
    opacity: 1;
    box-shadow: 0 0 12px rgba(52, 131, 250, 0.3);
  }

  .dot-r {
    background: #ef4444;
    box-shadow: 0 0 6px rgba(239, 68, 68, 0.2);
  }

  .dot-y {
    background: #f59e0b;
    box-shadow: 0 0 6px rgba(245, 158, 11, 0.2);
  }

  .dot-g {
    background: #22c55e;
    box-shadow: 0 0 6px rgba(34, 197, 94, 0.2);
  }

  .term-title {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: #3a4a60;
    margin-left: 8px;
    letter-spacing: 1px;
  }

  .term-body {
    padding: 24px;
  }

  .t-line {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    margin-bottom: 8px;
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }

  .t-p {
    color: var(--blue);
    flex-shrink: 0;
  }

  .t-c {
    color: var(--green);
  }

  .t-o {
    color: var(--muted);
    padding-left: 14px;
    flex: 1;
  }

  .t-v {
    color: #c8d0e0;
  }

  .t-ok {
    color: var(--green);
  }

  .t-num {
    color: #f59e0b;
  }

  .cursor {
    display: inline-block;
    width: 8px;
    height: 16px;
    background: var(--green);
    vertical-align: middle;
    margin-left: 3px;
    animation: blink 1s infinite;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border2);
    border: 1px solid var(--border2);
    border-radius: 8px;
    overflow: hidden;
    margin-top: 16px;
  }

  .stat-item {
    background: var(--bg2);
    padding: 16px;
    text-align: center;
  }

  .stat-num {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 24px;
    font-weight: 800;
    color: var(--blue);
    line-height: 1;
  }

  .stat-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 4px;
  }

  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .hero-name {
      line-height: 1;
      letter-spacing: -2px;
    }

    .hero-desc {
      max-width: 100%;
    }

    .terminal-card {
      max-width: 100%;
    }

    .stats-row {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 700px) {
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-actions a {
      text-align: center;
    }

    .stats-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    #hero {
      padding-top: 72px;
    }

    .hero-eyebrow {
      letter-spacing: 2.5px;
    }

    .hero-role {
      font-size: 12px;
      letter-spacing: 2px;
    }

    .hero-desc {
      font-size: 15px;
      line-height: 1.7;
    }

    .term-body {
      padding: 16px;
    }

    .t-line {
      font-size: 12px;
      gap: 7px;
    }
  }
</style>

