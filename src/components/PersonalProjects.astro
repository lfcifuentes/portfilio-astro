---
interface Project {
  title: string;
  description: string;
  image?: string;
  stack: string[];
  languages: string[];
  liveUrl?: string;
  githubUrl?: string;
  tag?: string;
}

interface Props {
  content?: {
    sectionTag: string;
    titlePrefix: string;
    titleAccent: string;
    subtitle: string;
    allFilter: string;
    projects: Array<{
      title: string;
      description: string;
      tag: string;
    }>;
  };
}

const projectsData: Project[] = [
  {
    title: 'Terminal Portfolio',
    description:
      'Interactive portfolio built as a terminal emulator. Features multi-language support, custom hooks, and multi-theme switching — all built with React + Vite and SCSS.',
    image: '/terminal_img_1.png',
    stack: ['React 19', 'Vite', 'SCSS', 'i18n', 'Custom Hooks'],
    languages: ['JavaScript'],
    liveUrl: 'https://terminal-portfolio-lcifuentes.netlify.app',
    githubUrl: 'https://github.com/lfcifuentes/terminal-portfolio',
    tag: 'Frontend',
  },
  {
    title: 'Email Indexer',
    description:
      'Full-stack email search engine. Indexes large volumes of emails using ZincSearch, exposes a REST API with Go + Chi, and provides a Vue 3 frontend with dark/light theme and Swagger docs.',
    image: 'https://raw.githubusercontent.com/lfcifuentes/email-indexer/main/images/index_dark.png',
    stack: ['Go', 'Chi', 'ZincSearch', 'Vue 3', 'TypeScript', 'Docker'],
    languages: ['Go', 'TypeScript'],
    githubUrl: 'https://github.com/lfcifuentes/email-indexer',
    tag: 'Full Stack',
  },
  {
    title: 'Go Redis Lock',
    description:
      'Reference implementation of a distributed lock system using Redis to prevent duplicate job executions. Useful pattern for cron jobs and background workers in concurrent environments.',
    image: '/go_redis_3.png',
    stack: ['Go', 'Redis', 'Docker'],
    languages: ['Go'],
    githubUrl: 'https://github.com/lfcifuentes/go-redis-lock-example',
    tag: 'Backend',
  },
  {
    title: 'Go SOLID',
    description:
      'Study project documenting SOLID design principles implemented in Go. Each principle (SRP, OCP, LSP, ISP, DIP) has its own directory with practical examples and explanations.',
    image: '/solid.png',
    stack: ['Go'],
    languages: ['Go'],
    githubUrl: 'https://github.com/lfcifuentes/go-solid',
    tag: 'Backend',
  },
  {
    title: 'DDD Go',
    description:
      'Reference backend project in Go applying Domain-Driven Design patterns with configuration and CLI tooling. Includes MongoDB integration, environment-based configuration, and test coverage for domain and application behavior.',
    stack: ['Go', 'DDD', 'MongoDB', 'Cobra', 'Viper', 'godotenv', 'Testify', 'UUID'],
    languages: ['Go'],
    githubUrl: 'https://github.com/lfcifuentes/ddd-go',
    tag: 'Backend',
  },
];

const languageFilters = ['All', ...new Set(projectsData.flatMap((project) => project.languages))];

const {
  content = {
    sectionTag: 'Side work',
    titlePrefix: 'Personal',
    titleAccent: 'projects.',
    subtitle: 'Front-end experiments, tools, and side projects built on my own time.',
    allFilter: 'All',
    projects: [
      {
        title: 'Terminal Portfolio',
        description:
          'Interactive portfolio built as a terminal emulator. Features multi-language support, custom hooks, and multi-theme switching — all built with React + Vite and SCSS.',
        tag: 'Frontend',
      },
      {
        title: 'Email Indexer',
        description:
          'Full-stack email search engine. Indexes large volumes of emails using ZincSearch, exposes a REST API with Go + Chi, and provides a Vue 3 frontend with dark/light theme and Swagger docs.',
        tag: 'Full Stack',
      },
      {
        title: 'Go Redis Lock',
        description:
          'Reference implementation of a distributed lock system using Redis to prevent duplicate job executions. Useful pattern for cron jobs and background workers in concurrent environments.',
        tag: 'Backend',
      },
      {
        title: 'Go SOLID',
        description:
          'Study project documenting SOLID design principles implemented in Go. Each principle (SRP, OCP, LSP, ISP, DIP) has its own directory with practical examples and explanations.',
        tag: 'Backend',
      },
      {
        title: 'DDD Go',
        description:
          'Reference backend project in Go applying Domain-Driven Design patterns with configuration and CLI tooling. Includes MongoDB integration, environment-based configuration, and test coverage for domain and application behavior.',
        tag: 'Backend',
      },
    ],
  },
} = Astro.props as Props;
---

<style>
  #personal-projects {
    padding: 100px 0;
    background: var(--bg2);
  }

  .section-head {
    margin-bottom: 48px;
  }

  .section-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--green);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .section-tag::before {
    content: '';
    width: 20px;
    height: 1px;
    background: var(--green);
  }

  .section-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 40px;
    font-weight: 800;
    letter-spacing: -1px;
    line-height: 1;
  }

  .section-title .accent {
    color: var(--blue);
  }

  .section-subtitle {
    font-size: 15px;
    color: var(--muted);
    margin-top: 14px;
    max-width: 520px;
    line-height: 1.7;
  }

  .project-filters {
    margin-top: 16px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .filter-chip {
    border: 1px solid var(--border2);
    background: var(--bg);
    color: var(--muted);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    padding: 6px 10px;
    border-radius: 6px;
    letter-spacing: 0.8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .filter-chip:hover {
    color: var(--text);
    border-color: rgba(52, 131, 250, 0.35);
  }

  .filter-chip.is-active {
    color: var(--blue);
    border-color: rgba(52, 131, 250, 0.35);
    background: var(--blue-dim);
  }

  /* ── Grid ── */
  .personal-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  /* ── Card ── */
  .p-card {
    background: var(--bg);
    border: 1px solid var(--border2);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s, transform 0.2s;
  }

  .p-card.is-hidden {
    display: none;
  }

  .p-card:hover {
    border-color: rgba(52, 131, 250, 0.3);
    transform: translateY(-3px);
  }

  /* ── Image ── */
  .p-card-img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    background: var(--bg3);
  }

  .p-card-img-placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--bg3);
    border-bottom: 1px solid var(--border2);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .p-card-img-placeholder svg {
    width: 36px;
    height: 36px;
    stroke: var(--border2);
    opacity: 0.5;
  }

  /* ── Body ── */
  .p-card-body {
    padding: 22px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 10px;
  }

  .p-card-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 3px;
    background: var(--blue-dim);
    border: 1px solid rgba(52, 131, 250, 0.25);
    color: var(--blue);
    text-transform: uppercase;
    letter-spacing: 1px;
    display: inline-block;
    align-self: flex-start;
  }

  .p-card-title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 18px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.4px;
    line-height: 1.2;
  }

  .p-card-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.7;
    flex: 1;
  }

  /* ── Stack tags ── */
  .p-card-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .p-card-stack span {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    padding: 2px 7px;
    border-radius: 3px;
    background: var(--bg3);
    border: 1px solid var(--border2);
    color: #4a5a70;
  }

  /* ── Links ── */
  .p-card-links {
    display: flex;
    gap: 10px;
    margin-top: 4px;
  }

  .p-card-link {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--blue);
    text-decoration: none;
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    gap: 5px;
    transition: opacity 0.2s;
  }

  .p-card-link:hover {
    opacity: 0.75;
  }

  .p-card-link svg {
    width: 12px;
    height: 12px;
    stroke: currentColor;
    flex-shrink: 0;
  }

  /* ── Empty state ── */
  .empty-state {
    grid-column: 1 / -1;
    border: 1px dashed var(--border2);
    border-radius: 12px;
    padding: 60px 32px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .filter-empty {
    grid-column: 1 / -1;
    border: 1px dashed var(--border2);
    border-radius: 12px;
    padding: 34px 24px;
    text-align: center;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 1px;
    display: none;
  }

  .filter-empty.is-visible {
    display: block;
  }

  .empty-state svg {
    width: 40px;
    height: 40px;
    stroke: var(--border2);
  }

  .empty-state p {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 1px;
  }

  /* ── Responsive ── */
  @media (max-width: 1000px) {
    .personal-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 700px) {
    #personal-projects {
      padding: 72px 0;
    }

    .section-head {
      margin-bottom: 36px;
    }

    .section-title {
      font-size: 32px;
    }

    .personal-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .section-title {
      font-size: 28px;
    }
  }

  @media (max-width: 375px) {
    #personal-projects {
      padding: 60px 0;
    }

    .section-title {
      font-size: 24px;
    }

    .p-card-body {
      padding: 16px;
    }
  }
</style>

<section id="personal-projects">
  <div class="container">
    <div class="section-head">
      <div class="section-tag">{content.sectionTag}</div>
      <h2 class="section-title">{content.titlePrefix} <span class="accent">{content.titleAccent}</span></h2>
      <p class="section-subtitle">
        {content.subtitle}
      </p>
      {projectsData.length > 0 && (
        <div class="project-filters" role="tablist" aria-label="Filter personal projects by language">
          {languageFilters.map((language, index) => (
            <button
              class={`filter-chip ${index === 0 ? 'is-active' : ''}`}
              type="button"
              data-language={language.toLowerCase()}
              aria-pressed={index === 0 ? 'true' : 'false'}
            >
              {language === 'All' ? content.allFilter : language}
            </button>
          ))}
        </div>
      )}
    </div>

    <div class="personal-grid">
      {projectsData.length === 0 ? (
        <div class="empty-state">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="3" />
            <path d="M3 9h18M9 21V9" />
          </svg>
          <p>// projects coming soon</p>
        </div>
      ) : (
        projectsData.map((project, idx) => {
          const translatedContent = content.projects[idx];
          return (
            <div class="p-card" data-languages={project.languages.map((language) => language.toLowerCase()).join(',')}>
              {project.image ? (
                <img
                  class="p-card-img"
                  src={project.image}
                  alt={`${translatedContent.title} screenshot`}
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="p-card-img-placeholder">
                  <svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="3" width="18" height="18" rx="2" />
                    <circle cx="8.5" cy="8.5" r="1.5" />
                    <path d="m21 15-5-5L5 21" />
                  </svg>
                </div>
              )}
              <div class="p-card-body">
                {translatedContent.tag && <span class="p-card-tag">{translatedContent.tag}</span>}
                <div class="p-card-title">{translatedContent.title}</div>
                <p class="p-card-desc">{translatedContent.description}</p>
                {project.stack.length > 0 && (
                  <div class="p-card-stack">
                    {project.stack.map((tech) => <span>{tech}</span>)}
                  </div>
                )}
                {(project.liveUrl || project.githubUrl) && (
                  <div class="p-card-links">
                    {project.liveUrl && (
                      <a href={project.liveUrl} target="_blank" rel="noopener noreferrer" class="p-card-link">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                          <polyline points="15 3 21 3 21 9" />
                          <line x1="10" y1="14" x2="21" y2="3" />
                        </svg>
                        Live
                      </a>
                    )}
                    {project.githubUrl && (
                      <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="p-card-link">
                        <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                        </svg>
                        GitHub
                      </a>
                    )}
                  </div>
                )}
              </div>
            </div>
          );
        })
      )}
      <div class="filter-empty" id="personal-filter-empty">// no projects found for this language</div>
    </div>
  </div>
</section>

<script is:inline>
  const personalSection = document.querySelector('#personal-projects');

  if (personalSection) {
    const chips = Array.from(personalSection.querySelectorAll('.filter-chip'));
    const cards = Array.from(personalSection.querySelectorAll('.p-card[data-languages]'));
    const emptyState = personalSection.querySelector('#personal-filter-empty');

    const setFilter = (language) => {
      chips.forEach((chip) => {
        const isActive = chip.dataset.language === language;
        chip.classList.toggle('is-active', isActive);
        chip.setAttribute('aria-pressed', String(isActive));
      });

      let visibleCount = 0;

      cards.forEach((card) => {
        const languages = (card.dataset.languages || '').split(',').map((item) => item.trim());
        const shouldShow = language === 'all' || languages.includes(language);
        card.classList.toggle('is-hidden', !shouldShow);
        if (shouldShow) visibleCount += 1;
      });

      if (emptyState) {
        emptyState.classList.toggle('is-visible', visibleCount === 0);
      }
    };

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const language = chip.dataset.language;
        if (language) setFilter(language);
      });
    });
  }
</script>
