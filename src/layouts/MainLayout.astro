---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
  noindex?: boolean;
  lang?: string;
  ogLocale?: string;
}

const {
  title,
  description = 'Luis Fernando Cifuentes — Senior Backend Engineer in Go specializing in distributed systems, event-driven architecture and Kubernetes. Based in Cali, Colombia.',
  canonicalURL,
  ogImage = '/og-image.svg',
  noindex = false,
  lang = 'en',
  ogLocale,
} = Astro.props;

const siteURL = Astro.site ?? new URL(Astro.url.origin);
const finalCanonicalURL = canonicalURL ?? new URL(Astro.url.pathname, siteURL).toString();
const finalOgImageURL = new URL(ogImage, siteURL).toString();
const finalOgLocale = ogLocale ?? (lang === 'es' ? 'es_ES' : 'en_US');
const scrollTopAriaLabel = lang === 'es' ? 'Volver arriba' : 'Scroll to top';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Luis Fernando Cifuentes',
  givenName: 'Luis Fernando',
  familyName: 'Cifuentes',
  url: siteURL.toString(),
  image: new URL('/og-image.svg', siteURL).toString(),
  jobTitle: 'Senior Backend Engineer',
  description,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Cali',
    addressCountry: 'CO',
  },
  knowsAbout: [
    'Python', 'Go', 'FastAPI', 'Apache Kafka',
    'Kubernetes', 'Docker', 'PostgreSQL', 'Redis',
    'Distributed Systems', 'Event-Driven Architecture',
    'Domain-Driven Design', 'Microservices',
  ],
  sameAs: [
    'https://www.linkedin.com/in/luis-fernando-cifuentes-3a6a90119/',
    'https://github.com/lfcifuentes',
  ],
  worksFor: {
    '@type': 'Organization',
    name: 'X-Grow AI',
  },
};
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Luis Fernando Cifuentes</title>
    <meta name="description" content={description} />
    <meta name="author" content="Luis Fernando Cifuentes" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta name="theme-color" content="#0a0e1a" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={finalCanonicalURL} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Luis Fernando Cifuentes`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={finalCanonicalURL} />
    <meta property="og:image" content={finalOgImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/svg+xml" />
    <meta property="og:locale" content={finalOgLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Luis Fernando Cifuentes`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={finalOgImageURL} />
    <meta name="twitter:image:alt" content="Luis Cifuentes — Senior Backend Engineer in Python &amp; Go" />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@400;500;600&family=Space+Grotesk:wght@700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      .scroll-top-btn {
        position: fixed;
        right: 24px;
        bottom: 24px;
        width: 46px;
        height: 46px;
        border-radius: 999px;
        border: 1px solid rgba(52, 131, 250, 0.35);
        background: rgba(10, 14, 26, 0.88);
        color: var(--blue);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 20;
        opacity: 0;
        visibility: hidden;
        transform: translateY(10px);
        transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease, border-color 0.2s ease;
        backdrop-filter: blur(6px);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
      }

      .scroll-top-btn svg {
        width: 18px;
        height: 18px;
        stroke: currentColor;
        stroke-width: 2.2;
      }

      .scroll-top-btn:hover {
        border-color: rgba(52, 131, 250, 0.65);
      }

      .scroll-top-btn.is-visible {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }

      .scroll-top-btn:focus-visible {
        outline: 2px solid rgba(52, 131, 250, 0.7);
        outline-offset: 2px;
      }

      @media (max-width: 520px) {
        .scroll-top-btn {
          right: 14px;
          bottom: 14px;
          width: 42px;
          height: 42px;
        }
      }
    </style>
  </head>
  <body>
    <slot />
    <button id="scroll-top-btn" class="scroll-top-btn" type="button" aria-label={scrollTopAriaLabel}>
      <svg viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 5v14" />
        <path d="m6 11 6-6 6 6" />
      </svg>
    </button>
    <script is:inline>
      const scrollTopButton = document.querySelector('#scroll-top-btn');

      if (scrollTopButton) {
        const toggleButton = () => {
          const isVisible = window.scrollY > 300;
          scrollTopButton.classList.toggle('is-visible', isVisible);
        };

        window.addEventListener('scroll', toggleButton, { passive: true });
        scrollTopButton.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        toggleButton();
      }
    </script>
  </body>
</html>
